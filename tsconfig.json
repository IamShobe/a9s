{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "exactOptionalPropertyTypes": true,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": true,
    "noImplicitOverride": true
  },
  "include": ["src", "scripts"]
}
